{
  "description": "paivot-graph hooks -- vault consultation, knowledge capture, stop reminder, session logging, scope guard, dispatcher mode (powered by pvg)",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pvg guard",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pvg hook user-prompt",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "paivot-graph:business-analyst|paivot-graph:designer|paivot-graph:architect|paivot-graph:sr-pm|paivot-graph:developer|paivot-graph:pm",
        "hooks": [
          {
            "type": "command",
            "command": "pvg hook subagent-start",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "paivot-graph:business-analyst|paivot-graph:designer|paivot-graph:architect|paivot-graph:sr-pm|paivot-graph:developer|paivot-graph:pm",
        "hooks": [
          {
            "type": "command",
            "command": "pvg hook subagent-stop",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pvg hook session-start",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pvg hook pre-compact",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pvg hook stop",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "pvg hook memory-read",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "pvg hook memory-write",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "pvg hook memory-edit",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pvg hook session-end",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
