{
  "description": "paivot-graph hooks -- vault consultation on session start, knowledge capture before compaction",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/vault-session-start.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/vault-pre-compact.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
